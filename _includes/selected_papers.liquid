{% assign sp_limit = page.selected_papers.limit | default: 0 | plus: 0 %}
{% assign sp_scrollable = page.selected_papers.scrollable %}

<div class="publications">
  {% if sp_scrollable %}
    <div style="max-height: 60vw; overflow-y: scroll; padding-right: 0.5rem;">
      {% if sp_limit > 0 %}
        {% bibliography --group_by none --query @*[selected=true]* --max {{ sp_limit }} %}
      {% else %}
        {% bibliography --group_by none --query @*[selected=true]* %}
      {% endif %}
    </div>
  {% else %}
    {% if sp_limit > 0 %}
      {% bibliography --group_by none --query @*[selected=true]* --max {{ sp_limit }} %}
    {% else %}
      {% bibliography --group_by none --query @*[selected=true]* %}
    {% endif %}
  {% endif %}
</div>
