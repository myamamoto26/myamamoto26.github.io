{% assign sp_scrollable = page.selected_papers.scrollable %}

<div class="publications">
  {% if sp_scrollable %}
    <div style="max-height: 60vw; overflow-y: scroll; padding-right: 0.5rem;">
      {% bibliography --group_by none --query @*[selected=true]* --max 3 %}
    </div>
  {% else %}
    {% bibliography --group_by none --query @*[selected=true]* %}
  {% endif %}
</div>
